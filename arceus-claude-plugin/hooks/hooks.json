{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/arc-hook.js",
            "timeout": 10,
            "statusMessage": "Enriching with Arceus graph context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/arc-hook.js",
            "timeout": 10,
            "statusMessage": "Checking Arceus index freshness..."
          }
        ]
      }
    ]
  }
}
